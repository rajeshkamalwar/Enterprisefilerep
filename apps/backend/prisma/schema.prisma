generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum ResourceType {
  GLOBAL
  DEPARTMENT
  PROJECT
  FOLDER
  FILE
}

enum SubjectType {
  USER
  GROUP
  ROLE
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGOUT
  DEPARTMENT_CREATED
  DEPARTMENT_UPDATED
  DEPARTMENT_DELETED
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  ROLE_CREATED
  PERMISSION_ASSIGNED
  ACCESS_REQUEST_CREATED
  ACCESS_REQUEST_APPROVED
  ACCESS_REQUEST_REJECTED
  ACCESS_DENIED
  FOLDER_CREATED
  FOLDER_UPDATED
  FILE_UPLOADED
  FILE_DOWNLOADED
  FILE_DELETED
  FILE_RESTORED
  FILE_PERMANENTLY_DELETED
  FILE_PREVIEWED
  FILE_VERSION_RESTORED
  FILE_OWNER_UPDATED
  FILE_SCAN_COMPLETED
  FILE_SCAN_FAILED
  SMTP_SETTINGS_UPDATED
  SMTP_TEST_QUEUED
  FOLDER_DELETED
  FOLDER_RESTORED
  FOLDER_PERMANENTLY_DELETED
  EMAIL_TEMPLATE_UPDATED
  SETTINGS_UPDATED
}

enum FileClassification {
  PUBLIC_INTERNAL
  INTERNAL
  CONFIDENTIAL
  RESTRICTED
}

enum ScanStatus {
  PENDING
  SCANNING
  CLEAN
  INFECTED
  FAILED
}

enum PreviewStatus {
  PENDING
  READY
  FAILED
  NOT_SUPPORTED
}

enum EmailDeliveryStatus {
  QUEUED
  SENT
  FAILED
}

enum AccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  fullName     String     @map("full_name")
  employeeCode String?    @map("employee_code")
  country      String?
  timezone     String     @default("Asia/Calcutta")
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  lastLoginAt  DateTime?  @map("last_login_at")

  departmentId           String?          @map("department_id")
  department             Department?      @relation(fields: [departmentId], references: [id])
  roles                  UserRole[]
  groupLinks             GroupMember[]
  sessions               UserSession[]
  auditLogs              AuditLog[]       @relation("AuditActor")
  createdFolders         Folder[]         @relation("FolderCreatedBy")
  createdFiles           RepositoryFile[] @relation("FileCreatedBy")
  uploadedVersions       FileVersion[]    @relation("VersionUploadedBy")
  requestedAccess        AccessRequest[]  @relation("AccessRequestRequester")
  reviewedAccessRequests AccessRequest[]  @relation("AccessRequestReviewer")

  @@map("users")
}

model Department {
  id                String   @id @default(cuid())
  name              String   @unique
  code              String   @unique
  description       String?
  storageQuotaBytes BigInt?  @map("storage_quota_bytes")
  status            String   @default("ACTIVE")
  createdAt         DateTime @default(now()) @map("created_at")

  users   User[]
  groups  Group[]
  folders Folder[]
  files   RepositoryFile[]

  @@map("departments")
}

model Role {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  description  String?
  isSystemRole Boolean  @default(false) @map("is_system_role")
  createdAt    DateTime @default(now()) @map("created_at")

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  key         String   @id
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  roles          RolePermission[]
  accessRequests AccessRequest[]

  @@map("permissions")
}

model UserRole {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id            String   @id @default(cuid())
  roleId        String   @map("role_id")
  permissionKey String   @map("permission_key")
  assignedAt    DateTime @default(now()) @map("assigned_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionKey], references: [key], onDelete: Cascade)

  @@unique([roleId, permissionKey])
  @@map("role_permissions")
}

model Group {
  id           String   @id @default(cuid())
  name         String
  description  String?
  departmentId String?  @map("department_id")
  createdAt    DateTime @default(now()) @map("created_at")

  department Department?   @relation(fields: [departmentId], references: [id])
  members    GroupMember[]

  @@unique([name, departmentId])
  @@map("groups")
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String   @map("group_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

model AccessControlEntry {
  id            String       @id @default(cuid())
  subjectType   SubjectType  @map("subject_type")
  subjectId     String       @map("subject_id")
  resourceType  ResourceType @map("resource_type")
  resourceId    String       @map("resource_id")
  permissionKey String       @map("permission_key")
  createdBy     String?      @map("created_by")
  createdAt     DateTime     @default(now()) @map("created_at")

  @@unique([subjectType, subjectId, resourceType, resourceId, permissionKey])
  @@index([subjectType, subjectId])
  @@index([resourceType, resourceId])
  @@map("access_control_entries")
}

model AccessRequest {
  id                    String              @id @default(cuid())
  requesterId           String              @map("requester_id")
  resourceType          ResourceType        @map("resource_type")
  resourceId            String              @map("resource_id")
  permissionKey         String              @map("permission_key")
  businessJustification String              @map("business_justification")
  status                AccessRequestStatus @default(PENDING)
  reviewerId            String?             @map("reviewer_id")
  decisionReason        String?             @map("decision_reason")
  decidedAt             DateTime?           @map("decided_at")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  requester  User       @relation("AccessRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  reviewer   User?      @relation("AccessRequestReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  permission Permission @relation(fields: [permissionKey], references: [key], onDelete: Restrict)

  @@index([requesterId])
  @@index([status])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("access_requests")
}

model UserSession {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  refreshTokenHash String    @map("refresh_token_hash")
  ipAddress        String?   @map("ip_address")
  userAgent        String?   @map("user_agent")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

model AuditLog {
  id            String      @id @default(cuid())
  actorUserId   String?     @map("actor_user_id")
  action        AuditAction
  entityType    String?     @map("entity_type")
  entityId      String?     @map("entity_id")
  entityName    String?     @map("entity_name")
  oldValueJson  Json?       @map("old_value_json")
  newValueJson  Json?       @map("new_value_json")
  ipAddress     String?     @map("ip_address")
  userAgent     String?     @map("user_agent")
  success       Boolean     @default(true)
  failureReason String?     @map("failure_reason")
  createdAt     DateTime    @default(now()) @map("created_at")

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Folder {
  id           String    @id @default(cuid())
  parentId     String?   @map("parent_id")
  name         String
  pathCache    String?   @map("path_cache")
  departmentId String?   @map("department_id")
  createdById  String    @map("created_by")
  updatedById  String?   @map("updated_by")
  deletedById  String?   @map("deleted_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  isDeleted    Boolean   @default(false) @map("is_deleted")

  parent     Folder?          @relation("FolderTree", fields: [parentId], references: [id])
  children   Folder[]         @relation("FolderTree")
  department Department?      @relation(fields: [departmentId], references: [id])
  createdBy  User             @relation("FolderCreatedBy", fields: [createdById], references: [id])
  files      RepositoryFile[]

  @@unique([parentId, name])
  @@index([parentId])
  @@index([departmentId])
  @@index([isDeleted])
  @@map("folders")
}

model RepositoryFile {
  id               String             @id @default(cuid())
  folderId         String             @map("folder_id")
  currentVersionId String?            @unique @map("current_version_id")
  originalName     String             @map("original_name")
  extension        String?
  mimeType         String?            @map("mime_type")
  classification   FileClassification @default(INTERNAL)
  description      String?
  departmentId     String?            @map("department_id")
  createdById      String             @map("created_by")
  updatedById      String?            @map("updated_by")
  deletedById      String?            @map("deleted_by")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  deletedAt        DateTime?          @map("deleted_at")
  isDeleted        Boolean            @default(false) @map("is_deleted")

  folder         Folder        @relation(fields: [folderId], references: [id])
  department     Department?   @relation(fields: [departmentId], references: [id])
  createdBy      User          @relation("FileCreatedBy", fields: [createdById], references: [id])
  currentVersion FileVersion?  @relation("CurrentFileVersion", fields: [currentVersionId], references: [id])
  versions       FileVersion[] @relation("FileVersions")

  @@index([folderId])
  @@index([departmentId])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([isDeleted])
  @@index([classification])
  @@map("files")
}

model FileVersion {
  id             String        @id @default(cuid())
  fileId         String        @map("file_id")
  versionNumber  Int           @map("version_number")
  storageKey     String        @unique @map("storage_key")
  storagePath    String        @map("storage_path")
  sizeBytes      BigInt        @map("size_bytes")
  checksumSha256 String        @map("checksum_sha256")
  mimeType       String?       @map("mime_type")
  scanStatus     ScanStatus    @default(PENDING) @map("scan_status")
  previewStatus  PreviewStatus @default(PENDING) @map("preview_status")
  uploadedById   String        @map("uploaded_by")
  uploadedAt     DateTime      @default(now()) @map("uploaded_at")

  file           RepositoryFile  @relation("FileVersions", fields: [fileId], references: [id], onDelete: Cascade)
  currentForFile RepositoryFile? @relation("CurrentFileVersion")
  uploadedBy     User            @relation("VersionUploadedBy", fields: [uploadedById], references: [id])

  @@unique([fileId, versionNumber])
  @@index([fileId])
  @@index([scanStatus])
  @@map("file_versions")
}

model EmailTemplate {
  id          String   @id @default(cuid())
  templateKey String   @unique @map("template_key")
  subject     String
  htmlBody    String   @map("html_body")
  textBody    String   @map("text_body")
  isEnabled   Boolean  @default(true) @map("is_enabled")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("email_templates")
}

model EmailDeliveryLog {
  id             String              @id @default(cuid())
  templateKey    String              @map("template_key")
  recipientEmail String              @map("recipient_email")
  subject        String
  status         EmailDeliveryStatus @default(QUEUED)
  failureReason  String?             @map("failure_reason")
  retryCount     Int                 @default(0) @map("retry_count")
  sentAt         DateTime?           @map("sent_at")
  createdAt      DateTime            @default(now()) @map("created_at")

  @@index([templateKey])
  @@index([status])
  @@index([createdAt])
  @@map("email_delivery_logs")
}

model SmtpSetting {
  id             String   @id
  host           String?
  port           Int      @default(587)
  username       String?
  passwordCipher String?  @map("password_cipher")
  secure         Boolean  @default(false)
  requireTls     Boolean  @default(true) @map("require_tls")
  fromEmail      String?  @map("from_email")
  fromName       String   @default("Enterprise File Repository") @map("from_name")
  replyTo        String?  @map("reply_to")
  lastTestStatus String   @default("not_run") @map("last_test_status")
  lastTestedAt   DateTime? @map("last_tested_at")
  updatedById    String?  @map("updated_by_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("smtp_settings")
}
