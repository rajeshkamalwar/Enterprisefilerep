# Copy this file to the VPS as .env.production and replace every placeholder.
# Never commit real secrets.

NODE_ENV=production
APP_NAME=Enterprise File Repository
APP_URL=https://files.example.com
PUBLIC_API_URL=https://files.example.com/api/v1
CORS_ORIGINS=https://files.example.com

PORT=4000
JWT_SECRET=replace-with-64-plus-random-characters
SMTP_SECRET=replace-with-64-plus-random-characters
SEED_ADMIN_PASSWORD=replace-before-first-seed

POSTGRES_DB=filerepo
POSTGRES_USER=filerepo
POSTGRES_PASSWORD=replace-with-strong-db-password
DATABASE_URL=postgresql://filerepo:replace-with-strong-db-password@postgres:5432/filerepo

REDIS_URL=redis://redis:6379
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_API_KEY=replace-with-strong-meilisearch-master-key
MEILISEARCH_FILES_INDEX=repository_files

CLAMAV_HOST=clamav
CLAMAV_PORT=3310

LOCAL_STORAGE_ROOT=/app/storage
BACKUP_LOCAL_ROOT=/app/backups
MAX_UPLOAD_BYTES=262144000
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=1 minute

# Configure real SMTP from the ERP UI after first login.
# Keep these notes with the deployment record:
# SMTP host: smtp.provider.com
# SMTP port: 587
# SMTP encryption: STARTTLS
# SMTP from email: noreply@example.com
# SMTP reply-to: support@example.com
