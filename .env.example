APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000/api/v1

DATABASE_URL=postgresql://filerepo:filerepo@localhost:5432/filerepo
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
SESSION_SECRET=change-me-session-secret

STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=./storage

MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=change-me-meili-key

CLAMAV_HOST=localhost
CLAMAV_PORT=3310

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=change-me
SMTP_SECURE=false
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Enterprise File Repository
SMTP_REPLY_TO=it-support@example.com
SMTP_REQUIRE_TLS=true

BACKUP_DESTINATION=s3-compatible-or-remote-path
